rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check authentication
    function isAuth() {
      return request.auth != null;
    }
    
    // Evidence directory logic
    match /evidence/{userId}/{allPaths=**} {
      // Only the user to whom the evidence belongs can upload
      allow write: if isAuth() && request.auth.uid == userId;
      // Anyone authenticated can read (guardians)
      allow read: if isAuth();
    }
    
    // Default fallback
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
