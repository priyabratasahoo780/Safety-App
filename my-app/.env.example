# ==================================================
# SafeSphereAI - Environment Variables
# ==================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Authentication (Clerk) ──────────────────────
# REQUIRED - Get from https://dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── AI Services ─────────────────────────────────
# REQUIRED for AI Assistant and Online Fake Call
# Get from https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# OPTIONAL - Alternative AI provider (Groq is faster/cheaper)
# Get from https://console.groq.com
EXPO_PUBLIC_GROQ_API_KEY=

# ─── Backend / WebSocket Server ──────────────────
# REQUIRED for real-time SOS notifications, Guardian alerts
# Must be your deployed backend URL (e.g. https://yourserver.com)
# For local Android emulator use: http://10.0.2.2:3000
# For local physical device use:  http://YOUR_LAN_IP:3000
EXPO_PUBLIC_BACKEND_URL=

# ─── Firebase ────────────────────────────────────
# REQUIRED - Configured in google-services.json and firebaseConfig.ts
# Get from https://console.firebase.google.com
# These are already embedded in google-services.json for Android.
# Only needed if you rotate keys or add a web/iOS app.
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=
