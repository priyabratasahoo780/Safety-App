# ==============================================================================
# SAFESPHERE - ENVIRONMENT VARIABLES
# ==============================================================================
# This is a unified .env.example file. 
# Copy the relevant sections to frontend (my-app/.env) or backend (backend/.env)

# ------------------------------------------------------------------------------
# FRONTEND VARIABLES (Place in my-app/.env)
# Note: All frontend environment variables MUST start with EXPO_PUBLIC_
# ------------------------------------------------------------------------------

# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
# - Required or optional: Required
# - Frontend or backend: Frontend
# - Purpose: Authenticates the mobile app with Clerk Auth
# - Feature affected: User login, signup, and authentication state

# EXPO_PUBLIC_GEMINI_API_KEY=
# - Required or optional: Required
# - Frontend or backend: Frontend
# - Purpose: Accesses Google Gemini models for generating fake call scripts
# - Feature affected: Online AI Fake Call feature

# EXPO_PUBLIC_GROQ_API_KEY=
# - Required or optional: Optional
# - Frontend or backend: Frontend
# - Purpose: Faster fallback inference for the Fake Call feature
# - Feature affected: Online AI Fake Call feature (fallback)

# EXPO_PUBLIC_BACKEND_URL=
# - Required or optional: Required
# - Frontend or backend: Frontend
# - Purpose: Instructs the app where to connect for real-time WebSockets and API requests
# - Feature affected: Real-time SOS alerts, Push Notification dispatch, Guardian Requests

# ------------------------------------------------------------------------------
# BACKEND VARIABLES (Place in backend/.env)
# ------------------------------------------------------------------------------

# FIREBASE_SERVICE_ACCOUNT=
# - Required or optional: Optional (Falls back to Application Default Credentials on GCP)
# - Frontend or backend: Backend
# - Purpose: JSON stringified service account key for Firebase Admin SDK
# - Feature affected: Guardian Request acceptance, Push Notification logic

# PORT=
# - Required or optional: Optional (Defaults to 3000)
# - Frontend or backend: Backend
# - Purpose: Defines the HTTP port for the Express server
# - Feature affected: Backend server listener

# VONAGE_API_KEY=
# - Required or optional: Required for SMS via Vonage
# - Frontend or backend: Backend
# - Purpose: Authenticate with Vonage API
# - Feature affected: SMS emergency dispatch

# VONAGE_API_SECRET=
# - Required or optional: Required for SMS via Vonage
# - Frontend or backend: Backend
# - Purpose: Secret key for Vonage API
# - Feature affected: SMS emergency dispatch

# VONAGE_FROM=
# - Required or optional: Optional (Defaults to 'SafeSphere')
# - Frontend or backend: Backend
# - Purpose: Sender ID for Vonage SMS
# - Feature affected: SMS emergency dispatch

# TWILIO_ACCOUNT_SID=
# - Required or optional: Required for SMS via Twilio
# - Frontend or backend: Backend
# - Purpose: Account SID for Twilio API
# - Feature affected: SMS emergency dispatch (fallback)

# TWILIO_AUTH_TOKEN=
# - Required or optional: Required for SMS via Twilio
# - Frontend or backend: Backend
# - Purpose: Auth Token for Twilio API
# - Feature affected: SMS emergency dispatch (fallback)

# TWILIO_PHONE_NUMBER=
# - Required or optional: Required for SMS via Twilio
# - Frontend or backend: Backend
# - Purpose: Sender phone number for Twilio SMS
# - Feature affected: SMS emergency dispatch (fallback)

# TWILIO_WHATSAPP_NUMBER=
# - Required or optional: Optional
# - Frontend or backend: Backend
# - Purpose: Sender phone number for Twilio WhatsApp integration
# - Feature affected: WhatsApp emergency dispatch

# FAST2SMS_API_KEY=
# - Required or optional: Required for Fast2SMS
# - Frontend or backend: Backend
# - Purpose: Authenticate with Fast2SMS for Indian phone numbers
# - Feature affected: SMS emergency dispatch (primary in India)

# CALLMEBOT_API_KEY=
# - Required or optional: Optional
# - Frontend or backend: Backend
# - Purpose: Authenticate with CallMeBot for free WhatsApp messages
# - Feature affected: WhatsApp emergency dispatch

# TELEGRAM_BOT_TOKEN=
# - Required or optional: Optional
# - Frontend or backend: Backend
# - Purpose: Telegram bot token to broadcast alerts freely
# - Feature affected: Telegram emergency broadcast

# TELEGRAM_CHAT_IDS=
# - Required or optional: Optional
# - Frontend or backend: Backend
# - Purpose: Comma-separated list of Telegram Chat IDs to receive the broadcasts
# - Feature affected: Telegram emergency broadcast
